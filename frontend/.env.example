# Copy this file to `.env` and adjust for your environment.
# NEVER commit `.env` — it is git-ignored on purpose.
#
# Only put NON-SECRET, public configuration here. Everything in a Vite
# `VITE_*` variable is inlined into the JavaScript bundle at build time and is
# therefore fully visible to anyone who opens the site. API keys, signing keys
# and passwords must never live in this file.

# Base URL of the Vet Manager Django API, without a trailing slash.
# The frontend appends `/api/v1/...` itself.
VITE_API_BASE_URL=http://localhost:8000
